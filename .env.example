# ─────────────────────────────────────────────────────────────────────────────
# Opus — Environment Configuration
# Copy to .env: cp .env.example .env
# Then run:    bash setup.sh   ← validates config + prints your Slack manifest
# ─────────────────────────────────────────────────────────────────────────────


# ── Slack App Credentials ─────────────────────────────────────────────────────
# Create your app at https://api.slack.com/apps (run `bash setup.sh` for the
# exact manifest to paste — it configures all scopes and events automatically)

# Bot User OAuth Token — OAuth & Permissions → "Bot User OAuth Token" (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-Level Token for Socket Mode — Basic Information → App-Level Tokens
# Click "Generate Token", name it anything, add the `connections:write` scope
# The token starts with xapp-
SLACK_APP_TOKEN=xapp-your-app-level-token

# Signing Secret — Basic Information → "Signing Secret" → Show
SLACK_SIGNING_SECRET=your-signing-secret


# ── Anthropic API ─────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-your-key


# ── Owner Config ──────────────────────────────────────────────────────────────
# Your Slack user ID — this gates all write bot commands (task:, done:, etc.)
# To find it: click your name in Slack → View Profile → ⋯ → Copy Member ID
OWNER_SLACK_ID=U0XXXXXXXXX

# Personal context for AI @mention classification (optional but recommended).
# Describe your role and what should become a task vs. just an FYI.
# Example: "I'm a backend engineer. Treat requests from my manager or infra
#           team as high-priority tasks. Bug reports = tasks. FYIs = not tasks."
CUSTOM_CONTEXT=


# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development


# ── Polling Intervals ─────────────────────────────────────────────────────────
# How often (in minutes) to poll each channel tier for new messages
# P0 = high-priority / fast-moving channels  |  P1 = standard channels
P0_POLL_INTERVAL=10
P1_POLL_INTERVAL=30

# Hours of Slack history to fetch the very first time a channel is polled
HISTORY_HOURS=24
