# ─────────────────────────────────────────────────────────────────────────────
# Opus — Environment Configuration
# Copy to .env: cp .env.example .env
# Then run:    bash setup.sh   ← validates config + prints your Slack manifest
# ─────────────────────────────────────────────────────────────────────────────


# ── Slack App Credentials ─────────────────────────────────────────────────────
# Create your app at https://api.slack.com/apps (run `bash setup.sh` for the
# exact manifest to paste — it configures all scopes and events automatically)

# Bot User OAuth Token — OAuth & Permissions → "Bot User OAuth Token" (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-Level Token for Socket Mode — Basic Information → App-Level Tokens
# Click "Generate Token", name it anything, add the `connections:write` scope
# The token starts with xapp-
SLACK_APP_TOKEN=xapp-your-app-level-token

# Signing Secret — Basic Information → "Signing Secret" → Show
SLACK_SIGNING_SECRET=your-signing-secret


# ── AI Provider ───────────────────────────────────────────────────────────────
# Which AI backend to use for task extraction, digests, and mention classification.
#
#   anthropic          → Anthropic Claude (default, best quality)
#   openai-compatible  → Any OpenAI-compatible API: Ollama, LM Studio, vLLM,
#                        Groq, actual OpenAI, etc.
#   local              → In-process llama.cpp via node-llama-cpp.
#                        No API key, no external service. Model is auto-downloaded
#                        on first run (~2.3 GB, Phi-3.5-mini Q4_K_M).
#                        Or run: cd server && npm run download-model
#
AI_PROVIDER=anthropic

# ── Anthropic (used when AI_PROVIDER=anthropic) ───────────────────────────────
# Get your key at https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-opus-4-6

# ── OpenAI-compatible (used when AI_PROVIDER=openai-compatible) ───────────────
# Point these at your local Ollama instance, LM Studio, Groq, or any
# service that speaks the OpenAI chat-completions API.
#
# Ollama default  → http://localhost:11434/v1  (no key required, use "ollama")
# LM Studio       → http://localhost:1234/v1   (no key required, use "lm-studio")
# Groq            → https://api.groq.com/openai/v1  (use your Groq API key)
# OpenAI          → https://api.openai.com/v1       (use your OpenAI API key)
#
OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
OPENAI_COMPATIBLE_API_KEY=ollama
OPENAI_COMPATIBLE_MODEL=llama3.2

# ── Local model (used when AI_PROVIDER=local) ─────────────────────────────────
# node-llama-cpp runs the model in-process — no external service required.
# On first use, a model is auto-downloaded to the models/ directory.
#
# Optional: set an explicit path to skip auto-download
#   LOCAL_MODEL_PATH=/path/to/your-model.gguf
#
# Optional: override which model to auto-download (any HuggingFace GGUF URI)
#   LOCAL_MODEL_HF_URI=hf:bartowski/Llama-3.2-3B-Instruct-GGUF/Llama-3.2-3B-Instruct-Q4_K_M.gguf
#
LOCAL_MODEL_PATH=
LOCAL_MODEL_HF_URI=


# ── Owner Config ──────────────────────────────────────────────────────────────
# Your Slack user ID — this gates all write bot commands (task:, done:, etc.)
# To find it: click your name in Slack → View Profile → ⋯ → Copy Member ID
OWNER_SLACK_ID=U0XXXXXXXXX

# Personal context for AI @mention classification (optional but recommended).
# Describe your role and what should become a task vs. just an FYI.
# Example: "I'm a backend engineer. Treat requests from my manager or infra
#           team as high-priority tasks. Bug reports = tasks. FYIs = not tasks."
CUSTOM_CONTEXT=


# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development


# ── Polling Intervals ─────────────────────────────────────────────────────────
# How often (in minutes) to poll each channel tier for new messages
# P0 = high-priority / fast-moving channels  |  P1 = standard channels
P0_POLL_INTERVAL=10
P1_POLL_INTERVAL=30

# Hours of Slack history to fetch the very first time a channel is polled
HISTORY_HOURS=24
